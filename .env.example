# Firebase Client Config (public - safe to share)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# Web Push (VAPID) - generate at https://vapidkeys.com or with web-push CLI
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Paystack (use test keys for development)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=

# Firebase Admin SDK (service account JSON as a single string)
FIREBASE_SERVICE_ACCOUNT_JSON='{}'

# External APIs
FOOTBALL_API_KEY=
OPENROUTER_API_KEY=
OPTIIC_API_KEY=
