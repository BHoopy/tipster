rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requester is an admin
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Free tips - public read, admin write
    match /free_tips/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // VIP tickets - public read, admin write
    match /vip_tickets/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // VIP ticket history - public read, admin write
    match /vip_tickets_history/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // Users - own read/write, admin can read all
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && isAdmin();
    }

    // Transactions - admin only
    match /transactions/{doc} {
      allow read: if request.auth != null && isAdmin();
      allow write: if request.auth != null && isAdmin();
    }

    // Settings - public read, admin write
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin();
    }

    // Verification OTPs - admin SDK only (no client access)
    match /verification_otps/{doc} {
      allow read, write: if false;
    }

    // Subscriptions (push notifications) - own read/write
    match /subscriptions/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == doc;
    }
  }
}
